# AutoCost AI — Environment Configuration
# Copy this file to .env and fill in your values

# ─── JWT Security ──────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production
JWT_SECRET=autocost-ai-super-secret-jwt-key-change-in-production

# ─── Email / SMTP (for OTP delivery) ───────────────────────
# Leave blank to run in DEV MODE (OTP logged to server console)
# Gmail example: use an App Password (not your normal password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM_NAME=AutoCost AI

# ─── Server ────────────────────────────────────────────────
PORT=3001

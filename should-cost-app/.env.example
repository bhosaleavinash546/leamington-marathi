# ============================================================
# CostLens — Environment Configuration
# Copy this file to .env and fill in your values.
# docker compose reads .env automatically from this folder.
# ============================================================

# ── Anthropic Claude AI (optional — app works without it) ───
# Get your key at: https://console.anthropic.com/
# Without this key, AI buttons use built-in demo responses.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Weekly Email Digest (optional) ──────────────────────────
# Leave blank to skip email sending (digest still runs, logged to console).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=costlens@no-reply.local

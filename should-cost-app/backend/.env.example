PORT=4000
NODE_ENV=development

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgres://postgres:password@localhost:5432/should_cost_db

# ── Auth ───────────────────────────────────────────────────
# REQUIRED. Must be a long, unique random string (>=16 chars).
# The server REFUSES to start in production with a placeholder or missing value.
# Generate one with:  openssl rand -base64 48
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=8h

# ── AI (Anthropic Claude) ──────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Email / SMTP (optional — OTP prints to console if unset) ─
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=costlens@no-reply.local

# ── Local dev convenience ──────────────────────────────────
# When 'true', signup/forgot-password OTPs are returned in the API response
# and auto-filled in the UI. NEVER enable in a shared or production
# environment — it exposes reset codes (account-takeover risk). The server
# refuses to boot in production if this is 'true'.
ALLOW_DEV_OTP=false

{
  "name": "auto-cost-reduction-ai",
  "private": true,
  "version": "3.2.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n SERVER,VITE -c cyan,yellow \"node server.mjs\" \"vite --port 5173\"",
    "server": "node server.mjs",
    "build": "tsc && vite build",
    "test": "node --test",
    "benchmark": "node benchmark/run.mjs",
    "benchmark:cost": "node benchmark/cost-run.mjs --min-hit 0.90 --max-mape 0.12",
    "benchmark:ideation": "node benchmark/ideation-eval.mjs",
    "kb:export": "node scripts/export-kb.mjs",
    "eval:status": "node scripts/eval-status.mjs",
    "preview": "vite preview",
    "mobile:build": "tsc && vite build && npx cap sync",
    "mobile:android": "npx cap open android",
    "mobile:ios": "npx cap open ios",
    "e2e": "node e2e/smoke.mjs",
    "test:integration": "node --test tests/http-integration.test.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.11.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "framer-motion": "^11.3.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.400.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.14",
    "occt-import-js": "^0.0.23",
    "pino": "^10.3.1",
    "pptxgenjs": "^3.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-router-dom": "^6.24.0",
    "recharts": "^3.8.1",
    "three": "^0.185.0",
    "vite-plugin-pwa": "^1.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "axe-core": "^4.12.1",
    "playwright-core": "^1.61.1",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.2.2",
    "vite": "^5.3.2"
  }
}

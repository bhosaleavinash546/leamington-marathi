# ─── Server ───────────────────────────────────────────────────────────
PORT=3001

# ─── Anthropic AI ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Authentication ────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=replace-with-a-strong-random-secret

# ─── Team Sync (optional) ──────────────────────────────────────────────
# TEAM_API_KEY=your-team-sync-key

# ─── SMTP Email (optional — OTPs logged to console if not set) ─────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ─── CORS (optional — defaults to localhost:5173,localhost:4173) ────────
# ALLOWED_ORIGINS=https://your-production-domain.com,http://localhost:5173

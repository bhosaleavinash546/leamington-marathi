# ─── Server ───────────────────────────────────────────────────────────
PORT=3002

# ─── Anthropic AI ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Authentication ────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=replace-with-a-strong-random-secret

# ─── Team Sync (optional) ──────────────────────────────────────────────
# TEAM_API_KEY=your-team-sync-key

# ─── SMTP Email (optional — OTPs logged to console if not set) ─────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ─── Metal Price API (optional — uses baseline prices if not set) ──────
# METAL_PRICE_API_KEY=your-key-from-metalpriceapi.com

# ─── CORS (required for Railway — set to your Railway domain) ──────────
# ALLOWED_ORIGINS=https://your-app.up.railway.app

# ── Live component pricing (optional) ────────────────────────────────────────
# Octopart/Nexar — OAuth2 client-credentials (preferred; get credentials at
# https://portal.nexar.com). The server exchanges these for an access token.
OCTOPART_CLIENT_ID=
OCTOPART_CLIENT_SECRET=
# Fallback: a ready-made Nexar access token (used only if ID/SECRET are unset)
OCTOPART_API_KEY=
# RS Components / Farnell element14 API keys (alternative providers)
RS_API_KEY=
FARNELL_API_KEY=

# ─── Enterprise deployment controls (see docs/CostVision-Secure-Deployment-CAPEE-Integration.md) ─
# Private AI routing (Option B): point ALL AI calls at an internal LLM gateway or
# Claude in your own cloud tenancy (AWS Bedrock / Google Vertex behind PrivateLink).
# Same models, same quality — compliant plumbing. Leave unset for the public API.
# ANTHROPIC_BASE_URL=https://llm-gateway.internal.example.com

# Air-gapped mode (Option A / sensitive programmes): hard-disables every external
# call (AI, news feeds, live component pricing). Deterministic costing, CAD geometry
# and the learning loop remain fully available. Enables witnessed zero-egress tests.
# AIR_GAPPED=1

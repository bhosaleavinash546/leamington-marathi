{
  "name": "should-cost-calculator",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:mobile": "tsc -p tsconfig.build.json && BUILD_TARGET=mobile vite build && npx cap sync",
    "mobile:android": "npm run build:mobile && npx cap open android",
    "mobile:ios": "npm run build:mobile && npx cap open ios",
    "cap:sync": "npx cap sync",
    "cap:run:android": "npx cap run android",
    "cap:run:ios": "npx cap run ios",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "server": "tsx server/index.ts",
    "accuracy": "tsx scripts/accuracy-report.ts",
    "dev:full": "concurrently \"npm run dev\" \"npm run server\"",
    "test:e2e": "tsx e2e/smoke.ts",
    "test:visual": "tsx e2e/visual.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@fontsource/inter": "^5.2.8",
    "@types/morgan": "^1.9.10",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "chart.js": "^4.5.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^8.5.2",
    "gsap": "^3.15.0",
    "helmet": "^8.2.0",
    "idb-keyval": "^6.2.5",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "morgan": "^1.11.0",
    "motion": "^12.41.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.11",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^25.1.0",
    "three": "^0.185.1",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pngjs": "^6.0.5",
    "@types/three": "^0.185.1",
    "concurrently": "^8.2.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  }
}

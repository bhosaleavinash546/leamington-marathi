# Copy to .env.local (or .env) when building for Capacitor mobile.
# Set to your deployed backend URL — the mobile app cannot reach localhost.
# Example (cloud):  VITE_API_BASE=https://api.costvision.app
# Example (LAN dev): VITE_API_BASE=http://192.168.1.100:3002
VITE_API_BASE=https://YOUR_BACKEND_URL_HERE
